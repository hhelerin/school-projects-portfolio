@model App.DTO.v1.ClassScheduling.UpdateClassInputModel
@{
    ViewData["Title"] = "Edit Class";
    var slug = ViewData["Slug"] as string;
    var note = ViewData["Note"] as string;
}

<h1>Edit Class</h1>

@if (!string.IsNullOrEmpty(note))
{
    <div class="alert alert-info">@note</div>
}

<hr />
<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit" asp-route-slug="@slug">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ClassId" />
            
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Details" class="form-label"></label>
                <textarea asp-for="Details" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Details" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Capacity" class="form-label"></label>
                <input asp-for="Capacity" class="form-control" type="number" min="1" />
                <span asp-validation-for="Capacity" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Index" asp-route-slug="@slug" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
