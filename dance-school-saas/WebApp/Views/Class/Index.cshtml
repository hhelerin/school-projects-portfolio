@model List<App.DTO.v1.ClassScheduling.ClassListItemDto>
@{
    ViewData["Title"] = "Classes";
    var slug = ViewData["Slug"] as string;
}

<h1>Classes</h1>

<p>
    <a asp-action="Create" asp-route-slug="@slug" class="btn btn-primary">Create New Class</a>
</p>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Dance Style</th>
            <th>Level</th>
            <th>Instructor</th>
            <th>Room</th>
            <th>Recurrence</th>
            <th>Capacity</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.DanceStyleName</td>
                <td>@item.LevelName</td>
                <td>@item.InstructorName</td>
                <td>@item.StudioRoomName</td>
                <td>@item.RecurrenceSummary</td>
                <td>@item.Capacity</td>
                <td>
                    <a asp-action="Detail" asp-route-slug="@slug" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-slug="@slug" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    <form asp-action="Delete" asp-route-slug="@slug" asp-route-id="@item.Id" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this class?')">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
