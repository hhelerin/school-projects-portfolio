@model App.DTO.v1.SchoolConfiguration.UpdateInstructorInputModel
@{
    ViewData["Title"] = "Edit Instructor";
    var slug = ViewData["Slug"] as string;
    var instructorId = ViewData["InstructorId"] as Guid?;
    var companyUsers = ViewData["CompanyUsers"] as List<App.DTO.v1.SchoolConfiguration.CompanyUserDropdownDto> ?? new List<App.DTO.v1.SchoolConfiguration.CompanyUserDropdownDto>();
}

<div class="container mt-4">
    <h1>Edit Instructor</h1>

    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit" asp-route-slug="@slug" asp-route-id="@instructorId" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PersonalId" class="form-label">Personal ID</label>
                    <input asp-for="PersonalId" class="form-control" />
                    <span asp-validation-for="PersonalId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ContactInfo" class="form-label">Contact Info</label>
                    <textarea asp-for="ContactInfo" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="ContactInfo" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="AppUserId" class="form-label">Portal User (optional)</label>
                    <select asp-for="AppUserId" class="form-select">
                        <option value="">-- No Portal Access --</option>
                        @foreach (var user in companyUsers)
                        {
                            <option value="@user.Id">@user.Email (@(user.FullName ?? "No name"))</option>
                        }
                    </select>
                    <span asp-validation-for="AppUserId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Details" class="form-label"></label>
                    <textarea asp-for="Details" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Details" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-action="Index" asp-route-slug="@slug" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}