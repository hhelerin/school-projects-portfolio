@model App.DTO.v1.Students.StudentDetailDto
@{
    ViewData["Title"] = "Student Details";
    var slug = ViewData["Slug"] as string;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Student Details</h1>
        <div>
            <a asp-action="Edit" asp-route-slug="@slug" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
            <form asp-action="Delete" asp-route-slug="@slug" asp-route-id="@Model.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this student?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <!-- Student Info Card -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Student Information</h5>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Personal ID</dt>
                <dd class="col-sm-9">@Model.PersonalId ?? "-"</dd>

                <dt class="col-sm-3">Contact Info</dt>
                <dd class="col-sm-9">@Model.ContactInfo ?? "-"</dd>

                <dt class="col-sm-3">Details</dt>
                <dd class="col-sm-9">@Model.Details ?? "-"</dd>

                <dt class="col-sm-3">Linked Account</dt>
                <dd class="col-sm-9">
                    @if (Model.AppUserId.HasValue)
                    {
                        <span class="badge bg-success">@Model.AppUserFullName</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">No linked account</span>
                    }
                </dd>

                <dt class="col-sm-3">Registered Date</dt>
                <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3">Last Updated</dt>
                <dd class="col-sm-9">@Model.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
            </dl>
        </div>
    </div>

    <!-- Placeholder Sections -->
    <div class="row">
        <!-- Active Packages -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Active Packages</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-0">Coming soon</p>
                </div>
            </div>
        </div>

        <!-- Trial Records -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Trial Records</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-0">Coming soon</p>
                </div>
            </div>
        </div>

        <!-- Attendance -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Attendance</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-0">Coming soon</p>
                </div>
            </div>
        </div>

        <!-- Showcase Eligibility -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Showcase Eligibility</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-0">Coming soon</p>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" asp-route-slug="@slug" class="btn btn-secondary">Back to List</a>
    </div>
</div>
