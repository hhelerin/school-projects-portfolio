@model IEnumerable<App.DTO.v1.Students.StudentListItemDto>
@{
    ViewData["Title"] = "Students";
    var slug = ViewData["Slug"] as string;
    var searchTerm = ViewData["SearchTerm"] as string;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Students</h1>
        <a asp-action="Create" asp-route-slug="@slug" class="btn btn-primary">Register New Student</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <!-- Search Form -->
    <form asp-action="Index" asp-route-slug="@slug" method="get" class="mb-4">
        <div class="input-group">
            <input type="text" name="searchTerm" class="form-control" placeholder="Search by name or contact info..." value="@searchTerm" />
            <button type="submit" class="btn btn-outline-secondary">Search</button>
            @if (!string.IsNullOrEmpty(searchTerm))
            {
                <a asp-action="Index" asp-route-slug="@slug" class="btn btn-outline-secondary">Clear</a>
            }
        </div>
    </form>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Contact Info</th>
                <th>Active Packages</th>
                <th>Has Login</th>
                <th>Registered Date</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.ContactInfo</td>
                    <td>@item.ActivePackageCount</td>
                    <td>
                        @if (item.HasAppUser)
                        {
                            <span class="badge bg-success">Yes</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">No</span>
                        }
                    </td>
                    <td>@item.CreatedAt.ToString("yyyy-MM-dd")</td>
                    <td class="text-end">
                        <a asp-action="Detail" asp-route-slug="@slug" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">View</a>
                        <a asp-action="Edit" asp-route-slug="@slug" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
