@model App.DTO.v1.SchoolConfiguration.CreateStudioInputModel
@{
    ViewData["Title"] = "Create Studio";
    var slug = ViewData["Slug"] as string;
}

<div class="container mt-4">
    <h1>Create Studio</h1>

    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create" asp-route-slug="@slug" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ContactInfo" class="form-label">Contact Info</label>
                    <textarea asp-for="ContactInfo" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="ContactInfo" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Details" class="form-label"></label>
                    <textarea asp-for="Details" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Details" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">Create</button>
                    <a asp-action="Index" asp-route-slug="@slug" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}