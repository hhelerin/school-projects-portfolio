@model App.DTO.v1.SchoolConfiguration.CreateStudioRoomInputModel
@{
    ViewData["Title"] = "Create Room";
    var slug = ViewData["Slug"] as string;
    var studioId = ViewData["StudioId"] as Guid?;
    var studioName = ViewData["StudioName"] as string;
}

<div class="container mt-4">
    <h1>Create Room</h1>
    <p class="text-muted">Studio: @studioName</p>

    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create" asp-route-slug="@slug" asp-route-studioId="@studioId" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Details" class="form-label"></label>
                    <textarea asp-for="Details" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Details" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">Create</button>
                    <a asp-action="Index" asp-route-slug="@slug" asp-route-studioId="@studioId" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}