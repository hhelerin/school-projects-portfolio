@model App.DTO.v1.SchoolConfiguration.StudioRoomDetailDto
@{
    ViewData["Title"] = "Edit Room";
    var slug = ViewData["Slug"] as string;
    var studioId = ViewData["StudioId"] as Guid?;
    var studioName = ViewData["StudioName"] as string;
    var roomId = Model.Id;
    var allFeatures = ViewData["AllFeatures"] as List<App.DTO.v1.SchoolConfiguration.FeatureDto> ?? new List<App.DTO.v1.SchoolConfiguration.FeatureDto>();
    var addFeatureModel = ViewData["AddFeatureModel"] as App.DTO.v1.SchoolConfiguration.AddStudioFeatureInputModel ?? new App.DTO.v1.SchoolConfiguration.AddStudioFeatureInputModel();
}

<div class="container mt-4">
    <h1>Edit Room</h1>
    <p class="text-muted">Studio: @studioName</p>

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Room Details</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" asp-route-slug="@slug" asp-route-studioId="@studioId" asp-route-id="@roomId" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input type="text" name="Name" class="form-control" value="@Model.Name" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Details</label>
                            <textarea name="Details" class="form-control" rows="3">@Model.Details</textarea>
                        </div>

                        <div class="mb-3">
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                            <a asp-action="Index" asp-route-slug="@slug" asp-route-studioId="@studioId" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Features</h5>
                </div>
                <div class="card-body">
                    @if (Model.Features != null && Model.Features.Any())
                    {
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Feature</th>
                                    <th>Valid From</th>
                                    <th>Valid Until</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var feature in Model.Features)
                                {
                                    <tr>
                                        <td>@feature.FeatureName</td>
                                        <td>@(feature.ValidFrom?.ToString("yyyy-MM-dd") ?? "—")</td>
                                        <td>@(feature.ValidUntil?.ToString("yyyy-MM-dd") ?? "—")</td>
                                        <td class="text-end">
                                            <form asp-action="RemoveFeature" asp-route-slug="@slug" asp-route-studioId="@studioId" asp-route-id="@roomId" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="studioFeatureId" value="@feature.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted">No features assigned.</p>
                    }

                    <hr />

                    <h6>Add Feature</h6>
                    <form asp-action="AddFeature" asp-route-slug="@slug" asp-route-studioId="@studioId" asp-route-id="@roomId" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row g-2">
                            <div class="col-md-4">
                                <select name="FeatureId" class="form-select" required>
                                    <option value="">Select Feature...</option>
                                    @foreach (var feature in allFeatures)
                                    {
                                        <option value="@feature.Id">@feature.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <input type="date" name="ValidFrom" class="form-control" placeholder="Valid From" />
                            </div>
                            <div class="col-md-3">
                                <input type="date" name="ValidUntil" class="form-control" placeholder="Valid Until" />
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-outline-primary w-100">Add</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}