@model IEnumerable<App.DTO.v1.SchoolConfiguration.StudioRoomListItemDto>
@{
    ViewData["Title"] = "Rooms";
    var slug = ViewData["Slug"] as string;
    var studioId = ViewData["StudioId"] as Guid?;
    var studioName = ViewData["StudioName"] as string;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>Rooms - @studioName</h1>
            <a asp-action="Detail" asp-controller="Studio" asp-route-slug="@slug" asp-route-id="@studioId" class="btn btn-outline-secondary btn-sm">← Back to Studio</a>
        </div>
        <a asp-action="Create" asp-route-slug="@slug" asp-route-studioId="@studioId" class="btn btn-primary">Create New Room</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-slug="@slug" asp-route-studioId="@studioId" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <form asp-action="Delete" asp-route-slug="@slug" asp-route-studioId="@studioId" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>